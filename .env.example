# Copy to .env and fill in. .env is gitignored.

# ── khata ──────────────────────────────────────────
KHATA_DB_PATH=data/khata.db
KHATA_MEDIA_DIR=data/media
KHATA_SECRET=change-me-to-a-random-32-byte-string
KHATA_USER=default
KHATA_TZ=Asia/Kolkata

# ── Dhan broker ────────────────────────────────────
# Generate access token daily at dhan.co → Trading APIs → Access DhanHQ APIs
# Token is a 24h JWT. Regenerate around 8:50 IST before market open.
DHAN_CLIENT_ID=
DHAN_ACCESS_TOKEN=

# Optional: Dhan postback webhook URL (for real-time order status)
# DHAN_POSTBACK_URL=
